        <mxCell id="postgres" value="PostgreSQL (Primary Database)&#10;- Users&#10;- Roles&#10;- Patients&#10;- Appointments&#10;- Doctors&#10;- Rooms&#10;- Billing&#10;- Medicine Stocks&#10;&#10;Schema owned by Database-final —&#10;central-service never runs migrate here." style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
